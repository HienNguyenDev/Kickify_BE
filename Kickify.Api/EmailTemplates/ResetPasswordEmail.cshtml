@model string

<body style="
    margin: 0;
    padding: 20px;
    background-color: #1a1f2e;
    font-family: Segoe UI, Tahoma, sans-serif;
    color: #ffffff;
  ">
    <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
        <tr>
            <td align="center">
                <table width="600"
                       cellpadding="0"
                       cellspacing="0"
                       role="presentation"
                       style="
            background-color: #1e2738;
            border-radius: 12px;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
            overflow: hidden;
            border: 1px solid #2a3545;
          ">
                    <!-- Header -->
                    <tr>
                        <td align="center"
                            style="
                background: linear-gradient(135deg, #0a0e1a 0%, #1a1f2e 100%);
                padding: 24px 0;
                border-bottom: 2px solid #7fff6f;
              ">
                            <span style="
                  font-size: 28px;
                  font-weight: 700;
                  color: #ffffff;
                  letter-spacing: 2px;
                ">
                                Kickify
                            </span>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding: 40px 30px">
                            <h2 style="
                  margin-top: 0;
                  font-size: 20px;
                  color: #ffffff;
                  font-weight: 600;
                ">
                                Xin chào!
                            </h2>
                            <p style="font-size: 16px; line-height: 1.6; color: #b8c5d6">
                                Chúng tôi đã nhận được yêu cầu đặt lại mật khẩu cho tài khoản của bạn.
                            </p>
                            <p style="font-size: 16px; line-height: 1.6; color: #b8c5d6">
                                <strong style="color: #7fff6f">Mật khẩu mới</strong> của bạn là:
                            </p>

                            <!-- Password Box -->
                            <div style="
                  background: linear-gradient(135deg, #1a2332 0%, #1e2738 100%);
                  border: 2px solid #7fff6f;
                  border-radius: 12px;
                  padding: 24px;
                  margin: 24px 0;
                  text-align: center;
                ">
                                <p style="
                    font-size: 32px;
                    font-weight: bold;
                    color: #7fff6f;
                    margin: 0;
                    letter-spacing: 2px;
                    word-break: break-all;
                  ">
                                    @Model
                                </p>
                            </div>

                            <p style="
                  font-size: 14px;
                  color: #ffd700;
                  background-color: #2a2416;
                  border-left: 4px solid #ffd700;
                  padding: 12px;
                  margin: 20px 0;
                  border-radius: 4px;
                ">
                                ⚠️ Vui lòng <strong>đổi mật khẩu ngay</strong> sau khi đăng nhập để bảo mật tài khoản.
                                Không chia sẻ mật khẩu này cho bất kỳ ai.
                            </p>
                            <p style="
                  font-size: 14px;
                  color: #8a98ad;
                  margin-top: 30px;
                  line-height: 1.5;
                ">
                                Nếu bạn không yêu cầu đặt lại mật khẩu, vui lòng liên hệ với chúng tôi ngay lập tức.
                            </p>

                            <hr style="
                  border: none;
                  border-top: 1px solid #2a3142;
                  margin: 30px 0;
                " />

                            <p style="
                  font-size: 14px;
                  color: #7fff6f;
                  font-weight: 600;
                  margin-bottom: 0;
                ">
                                Kickify - Kết nối đam mê bóng đá
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="
                background-color: #1a1f2e;
                padding: 15px;
                text-align: center;
                border-top: 1px solid #2a3545;
              ">
                            <p style="font-size: 12px; color: #b8c5d6; margin: 0 0 8px 0">
                                &copy; 2026 Kickify. All rights reserved.
                            </p>
                            <p style="font-size: 11px; color: #6a7685; margin: 0">
                                Email này được gửi tự động, vui lòng không trả lời.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>